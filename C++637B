#include <bits/stdc++.h>
using namespace std;

int main(){
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);
    int n; 
    cin >> n;
    vector<string> a(n);
    unordered_map<string, int> check;
    for (int i = 0; i < n; i++){
        cin >> a[i];
    }
    for (int i = n - 1; i >= 0; i--){
        if (check[a[i]]) {
            continue;
        }
        cout << a[i] << "\n";
        check[a[i]]++;
    }
    return 0;
}
